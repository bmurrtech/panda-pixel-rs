{
  "productName": "Panda Pixel",
  "version": "0.1.4-alpha",
  "identifier": "com.pandapixel.desktop",
  "build": {
    "beforeDevCommand": {
      "script": "trunk serve --port 8080",
      "cwd": "../src"
    },
    "beforeBuildCommand": {
      "script": "trunk build --release",
      "cwd": "../src"
    },
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Panda Pixel",
        "width": 800,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 600,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
